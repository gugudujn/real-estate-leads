    padding: "16px",
  },
  featureText: {
    marginTop: "8px",
    color: "#475569",
    fontSize: "14px",
    lineHeight: 1.5,
  },
  heroPanel: {
    backgroundColor: "#0f172a",
    color: "#ffffff",
    borderRadius: "24px",
    padding: "28px",
