  heroPanelItem: {
    backgroundColor: "rgba(255,255,255,0.08)",
    padding: "14px",
    borderRadius: "14px",
  },
  section: {
    maxWidth: "1000px",
    margin: "0 auto",
    padding: "32px 20px 56px",
  },
  sectionLight: {
    backgroundColor: "#ffffff",
    padding: "56px 20px",
  },
  sectionTitle: {
    fontSize: "32px",
    marginBottom: "10px",
  },
  sectionSubtitle: {
    fontSize: "16px",
    color: "#475569",
    lineHeight: 1.7,
    maxWidth: "800px",
  },
  widgetCard: {
    backgroundColor: "#ffffff",
    borderRadius: "24px",
    padding: "28px",
    border: "1px solid #e2e8f0",
    boxShadow: "0 12px 30px rgba(15, 23, 42, 0.08)",
    marginTop: "24px",
  },
  progressWrap: {
    marginBottom: "24px",
  },
  progressHeader: {
    display: "flex",
    justifyContent: "space-between",
    alignItems: "center",
    gap: "12px",
    marginBottom: "12px",
  },
  widgetTitle: {
    margin: 0,
    fontSize: "24px",
  },
  progressText: {
    margin: "4px 0 0",
    color: "#64748b",
    fontSize: "14px",
  },
  progressPercent: {
    color: "#64748b",
    fontWeight: "bold",
  },
  progressBarBg: {
    width: "100%",
    height: "10px",
    borderRadius: "999px",
    backgroundColor: "#e2e8f0",
    overflow: "hidden",
  },
  progressBarFill: {
    height: "100%",
    backgroundColor: "#0f172a",
    borderRadius: "999px",
    transition: "width 0.2s ease",
  },
  stepTitle: {
    fontSize: "28px",
    marginBottom: "8px",
  },
  stepSubtitle: {
    color: "#64748b",
    marginBottom: "20px",
    lineHeight: 1.6,
  },
  stepContent: {
    display: "grid",
    gap: "12px",
  },
  optionGrid: {
    display: "grid",
    gridTemplateColumns: "repeat(auto-fit, minmax(200px, 1fr))",
    gap: "12px",
  },
  optionButton: {
    padding: "16px",
    borderRadius: "14px",
    border: "1px solid #cbd5e1",
    backgroundColor: "#ffffff",
    cursor: "pointer",
    fontSize: "15px",
    textAlign: "left",
  },
  input: {
    width: "100%",
    boxSizing: "border-box",
    padding: "14px 16px",
    borderRadius: "12px",
    border: "1px solid #cbd5e1",
    fontSize: "15px",
  },
  textarea: {
    width: "100%",
    boxSizing: "border-box",
    padding: "14px 16px",
    borderRadius: "12px",
    border: "1px solid #cbd5e1",
    fontSize: "15px",
    resize: "vertical",
  },
  primaryButton: {
    backgroundColor: "#0f172a",
    color: "#ffffff",
    border: "none",
    borderRadius: "12px",
    padding: "14px 18px",
    fontWeight: "bold",
    cursor: "pointer",
    fontSize: "15px",
  },
  secondaryButton: {
    backgroundColor: "#ffffff",
    color: "#0f172a",
    border: "1px solid #cbd5e1",
    borderRadius: "12px",
    padding: "12px 16px",
    fontWeight: "bold",
    fontSize: "14px",
  },
  navRow: {
    marginTop: "18px",
    display: "flex",
    justifyContent: "space-between",
    alignItems: "center",
    gap: "12px",
    flexWrap: "wrap",
  },
  navHint: {
    color: "#94a3b8",
    fontSize: "13px",
  },
  errorText: {
    color: "#dc2626",
    marginTop: "12px",
  },
  successTitle: {
    fontSize: "28px",
    marginBottom: "8px",
  },
  successText: {
    color: "#475569",
    marginBottom: "20px",
  },
  summaryBox: {
    backgroundColor: "#f8fafc",
    border: "1px solid #e2e8f0",
    borderRadius: "16px",
    padding: "16px",
    marginBottom: "14px",
  },
  summaryText: {
    marginTop: "8px",
    color: "#334155",
    lineHeight: 1.6,
  },
  infoGrid: {
    maxWidth: "1200px",
    margin: "0 auto",
    display: "grid",
    gridTemplateColumns: "repeat(3, 1fr)",
    gap: "18px",
  },
  infoCard: {
    backgroundColor: "#ffffff",
    border: "1px solid #e2e8f0",
    borderRadius: "20px",
    padding: "22px",
    boxShadow: "0 8px 20px rgba(15, 23, 42, 0.05)",
  },
  infoText: {
    color: "#475569",
    lineHeight: 1.7,
    marginTop: "10px",
  },
  backupCard: {
    backgroundColor: "#ffffff",
    borderRadius: "24px",
    padding: "28px",
    border: "1px solid #e2e8f0",
    boxShadow: "0 12px 30px rgba(15, 23, 42, 0.08)",
  },
  backupGrid: {
    display: "grid",
    gridTemplateColumns: "1fr 1fr",
    gap: "12px",
    marginTop: "20px",
  },
};

export default App;
